{
  "version": 2,
  "builds": [
    {
      "src": "server-vercel-fixed.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server-vercel-fixed.ts"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "server-vercel-fixed.ts"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|webp|svg|ico))",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "server-vercel-fixed.ts"
    },
    {
      "src": "/(.*)",
      "dest": "server-vercel-fixed.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}