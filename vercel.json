{
  "version": 2,
  "functions": {
    "server.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.ts"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/server.ts"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|webp|svg|ico))",
      "dest": "/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/server.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}